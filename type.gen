-- queue blobs are per Memory Resrc or Micro
-- TODO perhaps simplify by removing defaults, requiring expected even if repeated
-- TODO perhaps simplify by putting Int/Default arguments after second Int subscript
MemoryIns = {
	-- n==0: departures from OldDerIns,Resrcs,Memorys,Micros,MiddleLoc,WholeFrm,Qualitys
	-- n>0: departures from n-1
	{"%(\
	function ConGetKey(key,val) for i,v in ipairs(key) do if orders[v] == nil then orders[v] = 0 end for j,u in ipairs(val) do local temp = v; if i ~= #key or j ~= #val then coroutine.yield(temp) else return temp end end end end\
	function ConGetOrd(key,val) for i,v in ipairs(key) do if orders[v] == nil then orders[v] = 0 end for j,u in ipairs(val) do local temp = orders[v]+j-1; if i ~= #key or j ~= #val then coroutine.yield(temp) else return temp end end end end\
	function ConGetVal(key,val) for i,v in ipairs(key) do if orders[v] == nil then orders[v] = 0 end for j,u in ipairs(val) do local temp = u; if i ~= #key or j ~= #val then coroutine.yield(temp) else return temp end end end end\
	function ConIncKey(key,val) for i,v in ipairs(key) do if orders[v] == nil then orders[v] = 0 end for j,u in ipairs(val) do local temp = v; if j == #val then orders[v] = orders[v] + #val end if i ~= #key or j ~= #val then coroutine.yield(temp) else return temp end end end end\
	function ConIncOrd(key,val) for i,v in ipairs(key) do if orders[v] == nil then orders[v] = 0 end for j,u in ipairs(val) do local temp = orders[v]+j-1; if j == #val then orders[v] = orders[v] + #val end if i ~= #key or j ~= #val then coroutine.yield(temp) else return temp end end end end\
	function ConIncVal(key,val) for i,v in ipairs(key) do if orders[v] == nil then orders[v] = 0 end for j,u in ipairs(val) do local temp = u; if j == #val then orders[v] = orders[v] + #val end if i ~= #key or j ~= #val then coroutine.yield(temp) else return temp end end end end\
	function ArgGetKey(key,val) for i,v in ipairs(key) do if aorders[v] == nil then aorders[v] = 0 end for j,u in ipairs(val) do local temp = v; if i ~= #key or j ~= #val then coroutine.yield(temp) else return temp end end end end\
	function ArgGetOrd(key,val) for i,v in ipairs(key) do if aorders[v] == nil then aorders[v] = 0 end for j,u in ipairs(val) do local temp = aorders[v]+j-1; if i ~= #key or j ~= #val then coroutine.yield(temp) else return temp end end end end\
	function ArgGetVal(key,val) for i,v in ipairs(key) do if aorders[v] == nil then aorders[v] = 0 end for j,u in ipairs(val) do local temp = u; if i ~= #key or j ~= #val then coroutine.yield(temp) else return temp end end end end\
	function ArgIncKey(key,val) for i,v in ipairs(key) do if aorders[v] == nil then aorders[v] = 0 end for j,u in ipairs(val) do local temp = v; if j == #val then aorders[v] = aorders[v] + #val end if i ~= #key or j ~= #val then coroutine.yield(temp) else return temp end end end end\
	function ArgIncOrd(key,val) for i,v in ipairs(key) do if aorders[v] == nil then aorders[v] = 0 end for j,u in ipairs(val) do local temp = aorders[v]+j-1; if j == #val then aorders[v] = aorders[v] + #val end if i ~= #key or j ~= #val then coroutine.yield(temp) else return temp end end end end\
	function ArgIncVal(key,val) for i,v in ipairs(key) do if aorders[v] == nil then aorders[v] = 0 end for j,u in ipairs(val) do local temp = u; if j == #val then aorders[v] = aorders[v] + #val end if i ~= #key or j ~= #val then coroutine.yield(temp) else return temp end end end end\
	function ConGetKeyOne(key) return ConGetKey({key},{\"\"}) end\
	function ConGetOrdOne(key) return ConGetOrd({key},{\"\"}) end\
	function ConGetValOne(key) return ConGetVal({key},{\"\"}) end\
	function ConIncKeyOne(key) return ConIncKey({key},{\"\"}) end\
	function ConIncOrdOne(key) return ConIncOrd({key},{\"\"}) end\
	function ConIncValOne(key) return ConIncVal({key},{\"\"}) end\
	function ArgGetKeyOne(key) return ArgGetKey({key},{\"\"}) end\
	function ArgGetOrdOne(key) return ArgGetOrd({key},{\"\"}) end\
	function ArgGetValOne(key) return ArgGetVal({key},{\"\"}) end\
	function ArgIncKeyOne(key) return ArgIncKey({key},{\"\"}) end\
	function ArgIncOrdOne(key) return ArgIncOrd({key},{\"\"}) end\
	function ArgIncValOne(key) return ArgIncVal({key},{\"\"}) end\
	function ConGetKeyLst(lst) return ConGetKey(lst,{\"\"}) end\
	function ConGetOrdLst(lst) return ConGetOrd(lst,{\"\"}) end\
	function ConGetValLst(lst) return ConGetVal(lst,{\"\"}) end\
	function ConIncKeyLst(lst) return ConIncKey(lst,{\"\"}) end\
	function ConIncOrdLst(lst) return ConIncOrd(lst,{\"\"}) end\
	function ConIncValLst(lst) return ConIncVal(lst,{\"\"}) end\
	function ArgGetKeyLst(lst) return ArgGetKey(lst,{\"\"}) end\
	function ArgGetOrdLst(lst) return ArgGetOrd(lst,{\"\"}) end\
	function ArgGetValLst(lst) return ArgGetVal(lst,{\"\"}) end\
	function ArgIncKeyLst(lst) return ArgIncKey(lst,{\"\"}) end\
	function ArgIncOrdLst(lst) return ArgIncOrd(lst,{\"\"}) end\
	function ArgIncValLst(lst) return ArgIncVal(lst,{\"\"}) end\
	function ConGetKeyPer(key,lst) return ConGetKey({key},lst) end\
	function ConGetOrdPer(key,lst) return ConGetOrd({key},lst) end\
	function ConGetValPer(key,lst) return ConGetVal({key},lst) end\
	function ConIncKeyPer(key,lst) return ConIncKey({key},lst) end\
	function ConIncOrdPer(key,lst) return ConIncOrd({key},lst) end\
	function ConIncValPer(key,lst) return ConIncVal({key},lst) end\
	function ArgGetKeyPer(key,lst) return ArgGetKey({key},lst) end\
	function ArgGetOrdPer(key,lst) return ArgGetOrd({key},lst) end\
	function ArgGetValPer(key,lst) return ArgGetVal({key},lst) end\
	function ArgIncKeyPer(key,lst) return ArgIncKey({key},lst) end\
	function ArgIncOrdPer(key,lst) return ArgIncOrd({key},lst) end\
	function ArgIncValPer(key,lst) return ArgIncVal({key},lst) end\
	)"},

	{"%(\
	function rnge (bas,max) for i = bas,max do if i ~= max then coroutine.yield(i) else return i end end end\
	function nest (bas,max,rep) for i = bas,max do for j = 1,rep do if i ~= max or j ~= rep then coroutine.yield(i) else return i end end end end\
	function func (mem) for i,v in ipairs(mem) do if i ~= #mem then coroutine.yield(v) else return v end end end\
	function cnct (src,dst) for i,v in ipairs(src) do for j,u in ipairs(v) do dst[#dst+1] = u end end return dst end\
	)"},

	{"Memory","Imagez","Int","0","Instr","OldDerIns"},
