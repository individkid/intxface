-- Resrc is sufficient for buffer structure, but binding info depend on Micro
MicroBinding = {
	{"%(function fnc (lst) for i,v in ipairs(lst) do if i ~= #lst then coroutine.yield(v) else return v end end end\
	function gnc (lst,oth) for i,v in ipairs(lst) do for j,w in ipairs(oth) do if i ~= #lst or j~= #oth then coroutine.yield(v) else return v end end end end\
	function hnc (lst,num) for i,v in ipairs(lst) do if i ~= #lst then coroutine.yield(i+num-1) else return i+num-1 end end end\
	function cat (one,oth,max) for i,v in ipairs(one) do max[#max+1] = v end for i,v in ipairs(oth) do max[#max+1] = v end return max end\
	\
	--[[bre = {\"UniformRes\",\"MatrixRes\", \"BasisRes\",  \"TriangleRes\",\"NumericRes\",\"VertexRes\", \"PipeRes\"}]]\
	    bph = {\"UniformPhs\",\"UniformPhs\",\"StoragePhs\",\"StoragePhs\", \"StoragePhs\",\"StoragePhs\",\"PipePhs\"}\
	    bbn = {\"0\",         \"1\",         \"2\",         \"3\",          \"4\",         \"5\",         \"0\"      }\
	--[[vre = {\"UniformRes\",\"MatrixRes\", \"TriangleRes\",\"VertexRes\", \"PipeRes\"}]]\
	    vph = {\"UniformPhs\",\"UniformPhs\",\"StoragePhs\", \"StoragePhs\",\"PipePhs\"}\
	    vbn = {\"0\",         \"1\",         \"3\",          \"5\",         \"0\"      }\
	--[[fre = {\"UniformRes\",\"MatrixRes\", \"IndexRes\",\"BringupRes\",\"PipeRes\"}]]\
	    fph = {\"UniformPhs\",\"UniformPhs\",\"IndexPhs\",\"FetchPhs\",  \"PipePhs\"}\
	    fbn = {\"0\",         \"1\",         \"0\",       \"0\",         \"0\"      }\
	--[[nre = {\"UniformRes\",\"MatrixRes\", \"PipeRes\"}]]\
	    nph = {\"UniformPhs\",\"UniformPhs\",\"PipePhs\"}\
	    nbn = {\"0\",         \"1\",         \"0\"      }\
	--[[lre = {\"UniformRes\",\"PipeRes\"}]]\
	    lph = {\"UniformPhs\",\"PipePhs\"}\
	    lbn = {\"0\",         \"0\"      }\
	--[[dre = {\"SwapRes\",\"ChainRes\",\"ImageRes\", \"StorageRes\"} cre = {\"ColorRes\", \"ImageRes\", \"StorageRes\"}]]\
	    dph = {\"SwapPhs\",\"FramePhs\",\"SamplePhs\",\"RelatePhs\" } cph = {\"RenderPhs\",\"SamplePhs\",\"RelatePhs\" }\
	    dbn = {\"0\",      \"0\",       \"7\",        \"6\"         } cbn = {\"0\",        \"7\",        \"6\"}\
	--[[pre = {\"PierceRes\"} rre = {\"RelateRes\"}]]\
	    pph = {\"RenderPhs\"} rph = {\"RenderPhs\"}\
	    pbn = {\"0\"}         rbn = {\"0\"}\
	lrm = {\"MicroFilRel\"} lrh = cat(lph,rph,{}) lrn = cat(lbn,rbn,{})\
	lpm = {\"MicroFilPie\"} lqh = cat(lph,pph,{}) lpn = cat(lbn,pbn,{})\
	lcm = {\"MicroFilCol\"} lch = cat(lph,cph,{}) lcn = cat(lbn,cbn,{})\
	crm = {\"MicroConPie\"} crh = cat(nph,pph,{}) crn = cat(nbn,pbn,{})\
	fdm = {\"MicroFetDrw\"} fdh = cat(fph,dph,{}) fdn = cat(fbn,dbn,{})\
	fcm = {\"MicroFetCol\"} fch = cat(fph,cph,{}) fcn = cat(fbn,cbn,{})\
	fpm = {\"MicroFetPie\"} fqh = cat(fph,pph,{}) fpn = cat(fbn,pbn,{})\
	frm = {\"MicroFetRel\"} frh = cat(fph,rph,{}) frn = cat(fbn,rbn,{})\
	vdm = {\"MicroVtxDrw\"} vdh = cat(vph,dph,{}) vdn = cat(vbn,dbn,{})\
	vcm = {\"MicroVtxCol\"} vch = cat(vph,cph,{}) vcn = cat(vbn,cbn,{})\
	vpm = {\"MicroVtxPie\"} vph = cat(vph,pph,{}) vpn = cat(vbn,pbn,{})\
	vrm = {\"MicroVtxRel\"} vrh = cat(vph,rph,{}) vrn = cat(vbn,rbn,{})\
	bdm = {\"MicroCopDrw\"} bdh = cat(bph,dph,{}) bdn = cat(bbn,dbn,{})\
